{
	"name": "ioium",
	"version": "1.0.1",
	"description": "A library focused on making CLI output beautiful with minimal effort.",
	"funding": {
		"type": "individual",
		"url": "https://github.com/sponsors/james-pre"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"exports": {
		".": "./dist/index.js",
		"./node": "./dist/node/index.js",
		"./*": "./dist/*.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"format:check": "prettier --check .",
		"format": "prettier --write .",
		"lint": "tsc --noEmit && eslint src",
		"prepublishOnly": "npx tsc"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/james-pre/ioium.git"
	},
	"author": "James Prevett <jp@jamespre.dev> (https://jamespre.dev)",
	"license": "LGPL-3.0-or-later",
	"bugs": {
		"url": "https://github.com/james-pre/ioium/issues"
	},
	"homepage": "https://github.com/james-pre/ioium#readme",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^24.7.0",
		"eslint": "^10.1.0",
		"globals": "^17.4.0",
		"prettier": "^3.2.5",
		"typedoc": "^0.28.18",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"utilium": "^3.0.0"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"optionalDependencies": {
		"zod": "^4.0.0"
	},
	"prettier": {
		"singleQuote": true,
		"useTabs": true,
		"trailingComma": "es5",
		"tabWidth": 4,
		"printWidth": 120,
		"arrowParens": "avoid",
		"experimentalOperatorPosition": "start"
	}
}
